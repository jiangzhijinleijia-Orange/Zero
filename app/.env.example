# Supabase プロジェクトの値に置き換える(Project Settings → API)
# anon key は RLS 前提の公開可能キー。service_role key は絶対にここに書かないこと。
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...

# 任意: Discord 通知(F-5-1)。未設定なら通知は送られない(アプリは正常動作)
# Discord のチャンネル設定 → 連携サービス → ウェブフック で取得
DISCORD_WEBHOOK_URL=
